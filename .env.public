# Configuração pública — pode ser versionada no GitHub.
# Segredos (chaves de API, WEB_SECRET_KEY, etc.) ficam em .env (ignorado pelo git).

WEB_VERBOSIDADE=0
# Restringir lista de UCs a UCs em que o docente é regente (1=sim, default; 0=todos os docentes)
WEB_ACESSO_APENAS_REGENTE=1
WEB_COOKIE_SECURE=1
WEB_MAX_USD_PER_USER_PER_MONTH=5
WEB_OUTPUT_RETENTION_HOURS=2
WEB_OUTPUT_MAX_GB=2
WEB_MAX_RUNNING_JOBS=8
WEB_THREADS=8

# Configurações dos providers e modelos (LLMs)
WEB_LLM_PROVIDER_OPTIONS=iaedu,openai,anthropic
WEB_LLM_MODEL_OPTIONS_JSON={"iaedu":["gpt-4o"],"openai":["gpt-4.1", "gpt-5.2"],"anthropic":["claude-sonnet-4-6","claude-opus-4-6"]}
WEB_FREE_LLM_PROVIDERS=iaedu
LLM_PRICING_JSON={"gpt-4.1": [2.0,8.0], "gpt-5.2": [1.75,14.0], "gpt-4o":[0.0,0.0],"claude-opus-4-6":[5,25],"claude-sonnet-4-6":[3,15]}

# Opção selecionada por omissão na combobox da Web (provider::modelo)
WEB_LLM_DEFAULT_CHOICE=anthropic::claude-sonnet-4-6

# Modelos default por provider
IAEDU_MODELO_ANALISE=gpt-4o
IAEDU_MODELO_CONDENSACAO=gpt-4o
ANTHROPIC_MODELO_ANALISE=claude-opus-4-6
ANTHROPIC_MODELO_CONDENSACAO=claude-sonnet-4-6
OPENAI_MODELO_ANALISE=gpt-5.2
OPENAI_MODELO_CONDENSACAO=gpt-4.1

# Anos letivos suportados 
#WEB_ANOS_LETIVOS_INICIO=2024
#WEB_ANOS_LETIVOS_FIM=2025

# Tolerância a falhas na chamada ao LLM
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_SECONDS=2
LLM_RETRY_MAX_SECONDS=20

# Enviar para LLM apenas o texto dos enunciados (e não PDFs)
LLM_ENUNCIADOS_APENAS_TEXTO=1

# Injeção de erros para garantir atenção humana na revisão.
REVIEW_ERROR_INJECTION=0
REVIEW_ERROR_COUNT=3
REVIEW_ERROR_TOLERANCE=1

# Verificação RGPD de dados pessoais nos enunciados antes de enviar para LLM.
# exclude: verifica e exclui ficheiros suspeitos (default); off: sem verificação.
WEB_RGPD_FILTRO=exclude

# Remover emoji de semáforo (🟢🟡🔴⚫) dos cabeçalhos na submissão ao SIGARRA.
# Os emoji ficam visíveis na prévia de revisão mas não no relatório institucional.
SIGARRA_REMOVER_EMOJI=true
